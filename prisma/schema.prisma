generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sites        Site[]
}

model Site {
  id        String    @id @default(cuid())
  name      String
  domain    String
  publicKey String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  events    Event[]
  sessions  Session[]

  @@index([domain])
  @@index([ownerId])
}

model Visitor {
  id          String    @id @default(cuid())
  visitorKey  String    @unique
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  events      Event[]
  sessions    Session[]
}

model Session {
  id         String    @id @default(cuid())
  sessionKey String    @unique
  siteId     String
  visitorId  String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  durationMs Int?
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitor    Visitor?  @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  events     Event[]

  @@index([siteId, startedAt])
  @@index([startedAt])
  @@index([visitorId])
}

model Event {
  id             String   @id @default(cuid())
  siteId         String
  visitorId      String?
  sessionId      String?
  type           String
  path           String?
  url            String?
  title          String?
  referrer       String?
  referrerDomain String?
  ipAddress      String?
  ipHash         String?
  country        String?
  region         String?
  city           String?
  asn            String?
  isp            String?
  userAgent      String?
  browser        String?
  os             String?
  device         String?
  screenWidth    Int?
  screenHeight   Int?
  language       String?
  timezone       String?
  isBot          Boolean  @default(false)
  botName        String?
  metadata       Json?
  createdAt      DateTime @default(now())
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitor        Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  session        Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([siteId, createdAt])
  @@index([siteId, type])
  @@index([siteId, type, createdAt])
  @@index([type, createdAt])
  @@index([siteId, path])
  @@index([siteId, referrerDomain])
  @@index([siteId, country])
  @@index([siteId, browser])
  @@index([siteId, os])
  @@index([siteId, device])
  @@index([ipAddress])
  @@index([ipHash])
  @@index([country])
  @@index([path])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  source    String
  type      String
  ipAddress String?
  ipHash    String?
  message   String
  isBot     Boolean?
  botName   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([createdAt, ipHash])
  @@index([createdAt, type])
  @@index([createdAt, source])
  @@index([createdAt, isBot])
  @@index([ipAddress])
  @@index([type])
}

model ServerMetric {
  id             String   @id @default(cuid())
  cpuPercent     Float?
  memoryUsedMb   Float?
  memoryTotalMb  Float?
  diskUsedGb     Float?
  diskTotalGb    Float?
  load1          Float?
  load5          Float?
  load15         Float?
  uptimeSeconds  Int?
  networkRxBytes BigInt?
  networkTxBytes BigInt?
  scope          String   @default("container")
  hostname       String?
  sampleKey      String?  @unique
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([scope, createdAt])
}

model HttpRequestBucket {
  id              String   @id @default(cuid())
  bucketStart     DateTime
  host            String
  method          String
  path            String
  status          Int
  trafficClass    String
  requestCount    Int      @default(0)
  durationTotalMs Float    @default(0)
  durationMaxMs   Float    @default(0)
  responseBytes   BigInt   @default(0)

  @@unique([bucketStart, host, method, path, status, trafficClass])
  @@index([bucketStart, status])
  @@index([host, bucketStart])
  @@index([path, bucketStart])
}

model HttpErrorSample {
  id            String   @id @default(cuid())
  requestKey    String   @unique
  occurredAt    DateTime
  host          String
  method        String
  path          String
  status        Int
  durationMs    Float
  responseBytes BigInt?
  proxyError    String?
  ipAddress     String?
  ipHash        String?
  isBot         Boolean  @default(false)
  botName       String?
  userAgent     String?
  cfRay         String?

  @@index([occurredAt, status])
  @@index([host, occurredAt])
  @@index([path, occurredAt])
  @@index([ipHash, occurredAt])
}

model IngestBatch {
  id         String   @id @default(cuid())
  source     String
  batchKey   String
  receivedAt DateTime @default(now())

  @@unique([source, batchKey])
  @@index([receivedAt])
}

model IngestionSource {
  id           String   @id @default(cuid())
  name         String   @unique
  lastSeenAt   DateTime
  agentVersion String?
  hostname     String?
}
